generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      String   @default("RIDER")
  isVerified Boolean @default(false)
  createdAt DateTime @default(now())

  rideRequests  RideRequest[]
  tripUsers     TripUser[]
  otps          Otp[]
  refreshTokens RefreshToken[]
  driverProfile DriverProfile?
}

model RideRequest {
  id             String   @id @default(uuid())
  userId         String
  pickupLat      Float
  pickupLng      Float
  dropLat        Float
  dropLng        Float
  pickupAddress  String?
  dropAddress    String?
  preferredTime  DateTime
  status         String   @default("PENDING")
  pendingCycles  Int      @default(0)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  // Relation back to TripUser (one-to-one via unique rideRequestId on TripUser)
  tripUser TripUser?
  // TripStops that reference this ride request (pickups/drops)
  tripStops TripStop[]
}

model Trip {
  id                   String    @id @default(uuid())
  status               String
  totalDistanceKm      Float
  estimatedEtaMinutes  Int
  detourRatio          Float
  lockedAt             DateTime?
  createdAt            DateTime  @default(now())
  completedAt          DateTime?

  tripUsers  TripUser[]
  tripStops  TripStop[]
  driverTrip DriverTrip?
}

model TripUser {
  id              String @id @default(uuid())
  tripId          String
  userId          String
  rideRequestId   String @unique
  fareShare       Float

  trip            Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)
  rideRequest     RideRequest @relation(fields: [rideRequestId], references: [id], onDelete: Cascade)
}

model TripStop {
  id                           String @id @default(uuid())
  tripId                       String
  stopOrder                    Int
  type                         String
  lat                          Float
  lng                          Float
  rideRequestId                String
  segmentDistKm                Float
  activePassengersOnSegment    Int

  trip            Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  rideRequest     RideRequest @relation(fields: [rideRequestId], references: [id], onDelete: Cascade)
}

model MatchCycleLog {
  id                      String   @id @default(uuid())
  runAt                   DateTime @default(now())
  triggerType             String
  pendingCountStart       Int
  tripsCreated            Int
  usersMatched            Int
  usersStillPending       Int
  autoCancelledCount      Int
  pairsRejectedDirection  Int
  pairsRejectedDetour     Int
  durationMs              Int
  errorMessage            String?
}

model Otp {
  id        String   @id @default(uuid())
  userId    String
  code      String
  type      String   @default("EMAIL_VERIFY")
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DriverProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  vehicleType  String
  licensePlate String
  createdAt    DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  trips DriverTrip[]
}

model DriverTrip {
  id              String    @id @default(uuid())
  driverProfileId String
  tripId          String    @unique
  status          String    @default("ACCEPTED")
  acceptedAt      DateTime  @default(now())
  startedAt       DateTime?
  completedAt     DateTime?

  driverProfile DriverProfile @relation(fields: [driverProfileId], references: [id])
  trip          Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
}