generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())

  rideRequests RideRequest[]
}

model RideRequest {
  id             String   @id @default(uuid())
  userId         String
  pickupLat      Float
  pickupLng      Float
  dropLat        Float
  dropLng        Float
  preferredTime  DateTime
  status         String   @default("PENDING")
  pendingCycles  Int      @default(0)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Trip {
  id                   String   @id @default(uuid())
  status               String
  totalDistanceKm      Float
  estimatedEtaMinutes  Int
  detourRatio          Float
  createdAt            DateTime @default(now())
  completedAt          DateTime?

  tripUsers TripUser[]
  tripStops TripStop[]
}

model TripUser {
  id              String @id @default(uuid())
  tripId          String
  userId          String
  rideRequestId   String @unique
  fareShare       Float

  trip            Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model TripStop {
  id                           String @id @default(uuid())
  tripId                       String
  stopOrder                    Int
  type                         String
  lat                          Float
  lng                          Float
  rideRequestId                String
  segmentDistKm                Float
  activePassengersOnSegment    Int

  trip            Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model MatchCycleLog {
  id                      String   @id @default(uuid())
  runAt                   DateTime @default(now())
  triggerType             String
  pendingCountStart       Int
  tripsCreated            Int
  usersMatched            Int
  usersStillPending       Int
  autoCancelledCount      Int
  pairsRejectedDirection  Int
  pairsRejectedDetour     Int
  durationMs              Int
  errorMessage            String?
}