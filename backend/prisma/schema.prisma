generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  createdAt DateTime @default(now())

  rideRequests RideRequest[]
  tripUsers    TripUser[]
}

model RideRequest {
  id             String   @id @default(uuid())
  userId         String
  pickupLat      Float
  pickupLng      Float
  dropLat        Float
  dropLng        Float
  preferredTime  DateTime
  requestTime    DateTime @default(now())
  status         String   @default("PENDING")
  pendingCycles  Int      @default(0)
  createdAt      DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id])
  tripUsers  TripUser[]
  tripStops  TripStop[]
}

model Trip {
  id                   String   @id @default(uuid())
  status               String   @default("ACTIVE")
  totalDistanceKm      Float
  estimatedEtaMinutes  Int
  detourRatio          Float
  createdAt            DateTime @default(now())
  completedAt          DateTime?

  tripUsers TripUser[]
  tripStops TripStop[]
}

model TripUser {
  id             String @id @default(uuid())
  tripId         String
  userId         String
  rideRequestId  String @unique
  fareShare      Float

  trip         Trip        @relation(fields: [tripId], references: [id])
  user         User        @relation(fields: [userId], references: [id])
  rideRequest  RideRequest @relation(fields: [rideRequestId], references: [id])
}

model TripStop {
  id                        String @id @default(uuid())
  tripId                    String
  stopOrder                 Int
  type                      String
  lat                       Float
  lng                       Float
  rideRequestId             String
  segmentDistKm             Float
  activePassengersOnSegment Int

  trip         Trip        @relation(fields: [tripId], references: [id])
  rideRequest  RideRequest @relation(fields: [rideRequestId], references: [id])
}

model MatchCycleLog {
  id                       String   @id @default(uuid())
  runAt                    DateTime @default(now())
  triggerType              String
  pendingCountStart        Int
  tripsCreated             Int      @default(0)
  usersMatched             Int      @default(0)
  usersStillPending        Int      @default(0)
  autoCancelledCount       Int      @default(0)
  pairsRejectedDirection   Int      @default(0)
  pairsRejectedDetour      Int      @default(0)
  durationMs               Int
  errorMessage             String?
}